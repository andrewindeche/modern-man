    "axios": "^1.15.2",
    "axios-mock-adapter": "^2.1.0",
    "babel-loader": "^10.1.1",
    "babel-preset": "^1.1.7",
    "babel-preset-react": "^6.24.1",
    "bootstrap": "^5.3.8",
    "css-loader": "^7.1.4",
    "env": "^0.0.2",
    "file-loader": "^6.2.0",
    "html-webpack-plugin": "^5.6.7",
    "identity-obj-proxy": "^3.0.0",
    "prop-types": "^15.8.1",
    "react": "^19.2.5",
    "react-bootstrap": "^2.10.10",
    "react-dom": "^19.2.5",
    "react-redux": "^9.2.0",
    "react-responsive": "^10.0.1",
