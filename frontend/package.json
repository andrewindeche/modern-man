{
  "name": "frontend",
  "version": "1.0.0",
  "engine": {
    "version": "v21.4.0"
  },
  "description": "A React App for modernman",
  "main": "./src/index.jsx",
  "scripts": {
    "start": "webpack serve --open --port 3000 --config webpack.prod.js",
    "lint": "eslint",
    "build": "webpack --config webpack.prod.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "clean": "rm -rf dist/",
    "dev": "webpack serve --open --port 3000 --config webpack.dev.js"
  },
  "jest": {
    "verbose": true,
    "testEnvironment": "jsdom",
    "moduleDirectories": [
      "node_modules",
      "src"
    ],
    "moduleNameMapper": {
      "\\.(css|less)$": "identity-obj-proxy"
    },
    "transform": {
      "^.+\\.jsx?$": "babel-jest",
      "^.+\\.(ico|svg|jpeg|jpg|png|gif|webp)$": "jest-transform-stub"
    }
  },
  "author": "Andrew Indeche",
  "license": "MIT",
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "babel-jest": "^30.3.0",
    "compression-webpack-plugin": "^12.0.0",
    "dotenv": "^17.4.2",
    "eslint": "^8.57.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jest": "^30.3.0",
    "jest-cli": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-fetch-mock": "^3.0.3",
    "jest-junit": "^16.0.0",
    "jest-transform-stub": "^2.0.0",
    "react-refresh": "^0.18.0",
    "react-test-renderer": "^19.2.5",
    "redux-mock-store": "^1.5.5",
    "webpack-bundle-analyzer": "^5.3.0"
  },
  "dependencies": {
    "@babel/cli": "^7.28.6",
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-regular-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.1",
    "@reduxjs/toolkit": "^2.11.2",
